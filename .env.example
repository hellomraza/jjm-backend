# Application
NODE_ENV=development
PORT=3000

# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=12345
DB_NAME=jjm_work_monitoring

# JWT Authentication
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRES_IN=1d

# AWS S3 Configuration
# Supported values: aws-s3, cloudflare-r2, mock
STORAGE_PROVIDER=aws-s3
AWS_REGION=ap-south-1
AWS_S3_BUCKET=jjm-work-monitoring
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key

# Cloudflare R2 Configuration
# Set STORAGE_PROVIDER=cloudflare-r2 to use R2.
CLOUDFLARE_R2_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
CLOUDFLARE_R2_BUCKET=jjm-work-monitoring
CLOUDFLARE_R2_ACCESS_KEY_ID=your-r2-access-key
CLOUDFLARE_R2_SECRET_ACCESS_KEY=your-r2-secret-key
CLOUDFLARE_R2_PUBLIC_BASE_URL=https://cdn.example.com

# Mock storage provider
# Set STORAGE_PROVIDER=mock to skip file upload and return random real image URLs.

# Google Maps API
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# CORS Configuration (for Next.js web app)
# Development: http://localhost:3001 (typical Next.js port)
# Production: https://yourdomain.com
# CRITICAL: Set this to your frontend domain for cookie-based auth to work
CORS_ORIGIN=http://localhost:3001

# Hybrid Authentication
# This backend supports BOTH:
# 1. HTTP-only cookies (Next.js web app)
# 2. Bearer tokens (React Native mobile app)
#
# Clients automatically use the appropriate method:
# - Web: Reads access_token in login response, browser sends cookie automatically
# - Mobile: Reads access_token in login response, sends via Authorization header
#
# No changes required in existing mobile app code!
